{
  "name": "job-aggregator-airtable",
  "version": "0.1.0",
  "private": false,
  "scripts": {
    "start": "node src/index.js",
    "ocr": "node src/agents/ocr.js",
    "test": "jest --runInBand",
    "discovery": "node src/agents/discovery.js",
    "scrape": "node src/agents/scraper.js",
    "extract": "node src/agents/extraction.js",
    "enrich": "node src/agents/enricher.js",
    "qa": "node src/agents/qa.js",
    "fingerprint": "node src/agents/fingerprinter.js",
    "reporter": "node src/agents/reporter.js",
    "review": "node src/agents/reviewer.js",
    "categorize": "node src/agents/categorizer.js",
    "pipeline": "node --max-old-space-size=4096 src/orchestrator.js",
    "audit:html-shapes": "node scripts/audit-html-extract-shapes.js",
    "benchmark": "node scripts/benchmark.js",
    "benchmark:compare": "node scripts/compare-benchmarks.js",
    "categorize:compare": "node scripts/compare-categorization-runs.js",
    "optimize": "node scripts/optimize-prompts.js",
    "notion-sync": "node src/agents/notion-sync.js --verbose",
    "notion-sync:dry": "node src/agents/notion-sync.js --dry-run --verbose",
    "notion-sync:companies": "node src/agents/notion-sync.js --companies-only --verbose",
    "notion-sync:jobs": "node src/agents/notion-sync.js --jobs-only --verbose",
    "notion-setup": "node src/agents/notion-setup.js",
    "notion-clear": "node src/agents/notion-clear.js"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@google/generative-ai": "^0.24.1",
    "@notionhq/client": "^3.1.3",
    "cheerio": "^1.0.0-rc.12",
    "node-fetch": "^2.6.7",
    "p-queue": "^7.4.1",
    "playwright": "^1.59.1"
  }
}

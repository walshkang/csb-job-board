# Anthropic API Key (Required for Haiku)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Notion Integration (Required for Sync)
NOTION_API_KEY=your_notion_api_key_here
NOTION_COMPANIES_DB_ID=your_companies_database_id_here
NOTION_JOBS_DB_ID=your_jobs_database_id_here

# Provider Configuration
LLM_PROVIDER=anthropic

